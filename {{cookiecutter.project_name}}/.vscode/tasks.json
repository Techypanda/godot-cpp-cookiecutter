{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "scons",
			"args": [
    			// enable for debugging with breakpoints
    			"dev_build=yes",
				"debug_symbols=yes"
  			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		}
	]
}